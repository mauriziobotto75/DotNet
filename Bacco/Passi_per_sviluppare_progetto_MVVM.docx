        xmlns:mc="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Random Joke Generator" Height="600" Width="700" 
        WindowStartupLocation="CenterScreen" 
        Background="LinearGradient(90deg, #667eea 0%, #764ba2 100%)">
    
    <Grid Background="#f0f2f5">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="600">
            
            <!-- Header -->
            <TextBlock Text="😂 Random Joke Generator 😂" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="#667eea"
                       TextAlignment="Center" 
                       Margin="0,0,0,30"/>

            <!-- Joke Display Box -->
            <Border BorderBrush="#667eea" BorderThickness="2" CornerRadius="10" Padding="20" Background="White" Margin="0,0,0,20">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200">
                    <TextBlock Text="{Binding CurrentJoke}" 
                               FontSize="18" 
                               Foreground="#333"
                               TextWrapping="Wrap"
                               LineHeight="28"/>
                </ScrollViewer>
            </Border>

            <!-- Category and Counter -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Category:" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding JokeCategory}" 
                               FontSize="14" 
                               Foreground="#667eea" 
                               FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="Jokes Loaded:" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding JokeCount}" 
