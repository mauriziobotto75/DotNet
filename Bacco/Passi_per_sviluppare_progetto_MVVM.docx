                               Foreground="#764ba2" 
                               FontWeight="Bold"/>
                </StackPanel>
            </Grid>

            <!-- Category Selection -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Select Category:" FontSize="12" Foreground="#666" Margin="0,0,0,8"/>
                <ComboBox SelectedItem="{Binding JokeCategory}" 
                         Height="40" 
                         FontSize="14"
                         Padding="10">
                    <ComboBoxItem>general</ComboBoxItem>
                    <ComboBoxItem>programming</ComboBoxItem>
                    <ComboBoxItem>knock-knock</ComboBoxItem>
                </ComboBox>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <Button Command="{Binding GetJokeCommand}" 
                       Width="140" 
                       Height="45" 
                       Margin="0,0,10,0"
                       Background="#667eea"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="Bold"
                       Cursor="Hand"
                       Content="Get Random Joke">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                               CornerRadius="5" 
                                               Padding="10">
                                            <ContentPresenter VerticalAlignment="Center" 
                                                            HorizontalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#764ba2"/>
                            </Trigger>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Command="{Binding GetJokeByCategoryCommand}" 
                       Width="140" 
                       Height="45"
                       Margin="0,0,10,0"
                       Background="#764ba2"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="Bold"
                       Cursor="Hand"
                       Content="Get Category Joke">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                               CornerRadius="5" 
                                               Padding="10">
                                            <ContentPresenter VerticalAlignment="Center" 
                                                            HorizontalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#667eea"/>
                            </Trigger>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Command="{Binding ClearCommand}" 
                       Width="100" 
                       Height="45"
                       Background="#e74c3c"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="Bold"
                       Cursor="Hand"
                       Content="Clear">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                               CornerRadius="5" 
                                               Padding="10">
                                            <ContentPresenter VerticalAlignment="Center" 
                                                            HorizontalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#c0392b"/>
                            </Trigger>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- Loading Indicator -->
            <TextBlock Text="Loading..." 
                      FontSize="14" 
                      Foreground="#667eea"
                      TextAlignment="Center"
                      Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                      Margin="0,0,0,10"/>

            <!-- Error Message -->
            <Border BorderBrush="#e74c3c" BorderThickness="1" CornerRadius="5" Padding="10" Background="#fadbd8" 
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                   Margin="0,0,0,10">
                <TextBlock Text="{Binding ErrorMessage}" 
                          Foreground="#c0392b"
                          FontSize="12"
                          TextWrapping="Wrap"/>
            </Border>

            <!-- Footer -->
            <TextBlock Text="Powered by API Ninjas" 
                      FontSize="11" 
                      Foreground="#999"
                      TextAlignment="Center"
                      Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>

