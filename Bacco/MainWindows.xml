<Window x:Class="BaccoPOS.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:views="clr-namespace:BaccoPOS.Views"
 Title="BACCO POS" Height="700" Width="1200">

<Grid>

    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*"/>
        <ColumnDefinition Width="3*"/>
    </Grid.ColumnDefinitions>

    <!-- ⭐ SINISTRA: TAVOLI -->
    <ScrollViewer Grid.Column="0" Background="#2D2D30">
        <ItemsControl ItemsSource="{Binding Tavoli}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="4"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Height="120"
                            Margin="5"
                            Background="DarkOrange"
                            Command="{Binding DataContext.ApriTavoloCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding}">
                        <StackPanel>
                            <TextBlock Text="{Binding Nome}" FontSize="18"/>
                            <TextBlock Text="{Binding Totale} €"/>
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>

    <!-- ⭐ DESTRA: COMANDA -->
    <Grid Grid.Column="1" Background="#3C3C3C">

        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <!-- LISTA ORDINE -->
        <DataGrid ItemsSource="{Binding Righe}" Grid.Row="0"/>

        <!-- MENU PRODOTTI -->
        <WrapPanel Grid.Row="1">

            <Button Content="Pizza" Width="100" Height="80"
                    Command="{Binding AggiungiCommand}" CommandParameter="Pizza"/>

            <Button Content="Birra" Width="100" Height="80"
                    Command="{Binding AggiungiCommand}" CommandParameter="Birra"/>

            <Button Content="Acqua" Width="100" Height="80"
                    Command="{Binding AggiungiCommand}" CommandParameter="Acqua"/>

            <Button Content="PAGA"
                    Width="150"
                    Height="80"
                    Background="Green"
                    Command="{Binding PagaCommand}"/>

        </WrapPanel>
    </Grid>

</Grid>
</Window>
