@model IEnumerable<T_Presenze>
@{
    ViewBag.Title = "Calendario Presenze";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<h2>Calendario Presenze</h2>
<div id="calendar"></div>
<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    var calendarEl = document.getElementById('calendar');
    var calendar = new FullCalendar.Calendar(calendarEl, {
        initialView: 'dayGridMonth',
        events: [
            @foreach (var presenza in Model)
            {
                foreach (var corpo in presenza.PresenzeCorpo)
                {
                    <text>
                    {
                        title: 'Ore: @(corpo.OraUscita - corpo.OraEntrata).TotalHours',
                        start: '@presenza.Data.ToString("yyyy-MM-dd")'
                    },
                    </text>
                }
            }
        ]
    });
    calendar.render();
});
</script>
